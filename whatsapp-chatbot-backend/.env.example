# ═══════════════════════════════════════════════════════════════
# AI WhatsApp Chatbot - Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Server Configuration
# ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here
CORS_ORIGIN=*
SERVE_DASHBOARD=false

# ───────────────────────────────────────────────────────────────
# Supabase Configuration
# Get these from Supabase Project Settings > API
# ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://jzbyoippazgdmvpypnnh.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp6YnlvaXBwYXpnZG12cHlwbm5oIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyMDU0MzYsImV4cCI6MjA4ODc4MTQzNn0.Mo2DZJIPU1PxG3mcINoESrtWhlUhOW_I5DvfblYI7Zs

# ───────────────────────────────────────────────────────────────
# Meta WhatsApp Business API Configuration
# Get these from Meta Business Manager: https://business.facebook.com
# ───────────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_API_VERSION=v18.0

# ───────────────────────────────────────────────────────────────
# AI Provider Configuration
# Choose your provider: gemini | openai | anthropic | local
# ───────────────────────────────────────────────────────────────
AI_PROVIDER=gemini

# Gemini Configuration (Free tier available)
# Get API key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro

# OpenAI Configuration (Optional - for future use)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo

# Anthropic Configuration (Optional - for future use)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-instant-1

# Local LLM Configuration (Optional - for future use)
LOCAL_LLM_URL=http://localhost:8000
LOCAL_LLM_MODEL=llama-2-7b

# ───────────────────────────────────────────────────────────────
# Google Sheets Integration (Optional but recommended)
# For lead capture and management
# ───────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----"
GOOGLE_SHEETS_SHEET_NAME=Leads

# ───────────────────────────────────────────────────────────────
# Human Handoff Configuration
# ───────────────────────────────────────────────────────────────
ADMIN_PHONE_NUMBER=your_admin_phone_number
HANDOFF_PAUSE_DURATION_HOURS=24

# ───────────────────────────────────────────────────────────────
# Dental Clinic Configuration
# Customize for your practice
# ───────────────────────────────────────────────────────────────
CLINIC_NAME=Dental Studio
DOCTOR_NAME=Dr. Elena Voss
CLINIC_PHONE=(555) 123-4567
CLINIC_EMAIL=hello@dentalstudio.com
CLINIC_ADDRESS=123 Smile Street, Dental City, DC 12345

# ───────────────────────────────────────────────────────────────
# Session Management
# ───────────────────────────────────────────────────────────────
SESSION_TIMEOUT_MS=3600000
MAX_HISTORY_LENGTH=20